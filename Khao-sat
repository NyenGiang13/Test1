<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Khảo sát uy tín</title>
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background-color: #f0f2f5;
            font-family: sans-serif;
            overflow: hidden;
            touch-action: none;
        }

        h1 { font-size: 22px; text-align: center; padding: 20px; line-height: 1.5; }

        .step { display: none; flex-direction: column; align-items: center; width: 100%; }
        .active { display: flex; }

        /* Khung chứa nút cực kỳ quan trọng */
        .btn-container {
            position: relative;
            width: 100%;
            height: 100px;
            display: flex;
            justify-content: center; /* Căn giữa vùng chứa */
            align-items: center;
        }

        button {
            width: 130px;
            height: 50px;
            font-size: 16px;
            font-weight: bold;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            box-sizing: border-box;
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

        /* Nút ở Bước 1 */
        .btn-male { background: #007bff; color: white; margin-right: 10px; }
        .btn-female { background: #e83e8c; color: white; margin-left: 10px; }

        /* Nút ở Bước 2 - Fix lỗi nhảy vị trí */
        #yes {
            background: #28a745;
            color: white;
            position: absolute; /* Dùng absolute để tách biệt hoàn toàn */
            left: 50%;
            margin-left: -140px; /* Đẩy sang trái 140px tính từ giữa */
        }

        #no {
            background: #dc3545;
            color: white;
            position: absolute;
            left: 50%;
            margin-left: 10px; /* Nằm bên phải 10px tính từ giữa */
            transition: all 0.12s ease-out;
            z-index: 999;
        }
    </style>
</head>
<body>

    <div id="step1" class="step active">
        <h1>Chọn giới tính để tiếp tục:</h1>
        <div class="btn-container">
            <button class="btn-male" onclick="choose('male')">Nam</button>
            <button class="btn-female" onclick="choose('female')">Nữ</button>
        </div>
    </div>

    <div id="step2" class="step">
        <h1 id="question">Đang tải...</h1>
        <div class="btn-container">
            <button id="yes" onclick="ans()">Có!</button>
            <button id="no" onmouseover="move()" onclick="move()" ontouchstart="move()">Không!</button>
        </div>
    </div>

    <script>
        let gender = '';

        function choose(g) {
            gender = g;
            const q = document.getElementById('question');
            const y = document.getElementById('yes');
            const n = document.getElementById('no');

            if(g === 'male') {
                q.innerHTML = "Mày có phải là <br><b>GAY</b> không? :)))";
                y.innerText = "Đúng, t bị gay!";
                n.innerText = "Méo nhé!";
            } else {
                q.innerHTML = "Bạn có phải là <br><b>LESBIAN</b> không? :)))";
                y.innerText = "Đúng, t bị les!";
                n.innerText = "Méo nhé!";
            }

            document.getElementById('step1').classList.remove('active');
            document.getElementById('step2').classList.add('active');
        }

        function move() {
            const btn = document.getElementById("no");
            
            // QUAN TRỌNG: Xóa margin-left để không bị lệch khi nhảy tọa độ mới
            btn.style.marginLeft = "0"; 

            const maxX = window.innerWidth - btn.offsetWidth - 20;
            const maxY = window.innerHeight - btn.offsetHeight - 20;

            const randomX = Math.floor(Math.random() * maxX);
            const randomY = Math.floor(Math.random() * maxY);

            btn.style.position = "fixed";
            btn.style.left = randomX + "px";
            btn.style.top = randomY + "px";
        }

        function ans() {
            alert(gender === 'male' ? 'Biết ngay mà! Đã bảo rồi! =))' : 'Biết ngay mà! Đã bảo rồi! =))');
            window.location.href = "https://www.youtube.com/watch?v=dQw4w9WgXcQ";
        }

        // Chống zoom iPhone
        document.addEventListener('touchstart', (e) => {
            if (e.touches.length > 1) e.preventDefault();
        }, { passive: false });
    </script>
</body>
</html>
